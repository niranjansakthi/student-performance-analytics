# Project Meta
PROJECT_NAME="ERP-Based Student Annual Report Generator"
API_V1_STR="/api/v1"

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=student_erp

# Combined database URL for connection (uses asyncpg driver)
# Format: postgresql+asyncpg://user:password@server:port/db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/student_erp
